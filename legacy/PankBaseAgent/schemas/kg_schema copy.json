{
  "knowledge_graph_schema": {
    "node_types": {
      "coding_elements;gene": {
        "description": "Genes from Ensembl database with genomic coordinates and annotations",
        "properties": {
          "id": "String",
          "id_version": "Int",
          "description": "String",
          "chr": {
            "type": "String",
            "examples": ["1", "2", "X", "Y"]
          },
          "start_loc": "Int",
          "end_loc": "Int",
          "strand": {
            "type": "String",
            "values": ["-1.0", "1.0"]
          },
          "name": "String",
          "GC_percentage": "Float",
          "type": {
            "type": "String",
            "examples": ["protein_coding", "lncRNA", "miRNA", "snRNA", "snoRNA", "rRNA", "TEC"]
          },
          "link": "String",
          "gencode_annotation": {
            "type": "String",
            "values": ["GENCODE basic"]
          },
          "data_version": {
            "type": "String",
            "values": ["GRCh38.p14"]
          },
          "data_source": {
            "type": "String",
            "values": ["Ensembl"]
          }
        }
      },
      "OCR": {
        "description": "Open Chromatin Regions from scATAC-seq data",
        "properties": {
          "id": "String",
          "data_version": {
            "type": "String",
            "values": ["2025_05_28"]
          },
          "data_source": {
            "type": "String",
            "values": ["PanKbase"]
          }
        }
      },
      "ontology;gene_ontology": {
        "description": "Genes from Ensembl database with genomic coordinates and annotations",
        "properties": {
          "id": "String",
          "name": "String",
          "description": "String",
          "link": "String",
          "data_version": "String"
        }
      },
      "ontology;disease": {
        "description": "Diseases from MONDO ontology, particularly Type 1 Diabetes",
        "properties": {
          "url": "String",
          "id": {"type": "String", "values": ["MONDO_0005147"]},
          "definition": "String",
          "name": {"type": "String", "values": ["type 1 diabetes"]},
          "synonyms": "String",
          "data_version": "String",
          "data_source": "String"
        }
      },
      "variants;sequence_variant;snp": {
        "description": "Single nucleotide polymorphisms (SNPs) from NCBI database",
        "properties": {
          "id": {
            "type": "String",
            "examples": ["rs1272", "rs1298"]
          },
          "chr": "String",
          "start_loc": "Int",
          "end_loc": "Int",
          "ref": "String",
          "alt": "String",
          "variant_suspect_reason": "String",
          "freq": "String",
          "HGVS_name": "String",
          "non_synonymous_frameshift": "String",
          "non_synonymous_missense": "String",
          "non_synonymous_nonsense": "String",
          "in_3prime_UTR": "String",
          "in_5prime_UTR": "String",
          "in_acceptor_splice_site": "String",
          "in_donor_splice_site": "String",
          "in_intron": "String",
          "in_3prime_gene_region": "String",
          "in_5prime_gene_region": "String",
          "common_SNP": "String",
          "type": "String",
          "data_version": "String",
          "data_source": "String"
        }
      },
      "ontology;cell_type": {
        "description": "Cell types from Cell Ontology, particularly pancreatic cell types",
        "properties": {
          "url": "String",
          "id": "String",
          "definition": "String",
          "name": {
            "type": "String",
            "examples": ["Beta Cell", "Alpha Cell", "Delta Cell", "Acinar Cell", "Ductal Cell", "Stellate Cell", "Endothelial Cell", "Immune Cell"]
          },
          "synonyms": "String",
          "data_version": "String",
          "data_source": "String"
        }
      }
    },
    "edge_types": {
      "physical_interaction": {
        "description": "Protein-protein physical interactions from BioGRID",
        "source_node_type": "gene",
        "target_node_type": "gene",
        "properties": {
          "start": "String",
          "end": "String",
          "biogrid_interaction_id": "Int",
          "Entrez_ID_A": "Int",
          "Entrez_ID_B": "Int",
          "biogrid_id_interactor_a": "Int",
          "biogrid_id_interactor_b": "Int",
          "official_symbol_interactor_a": "String",
          "official_symbol_interactor_b": "String",
          "experimental_system": "String",
          "experimental_system_type": {
            "type": "String",
            "values": ["physical"]
          },
          "author": "String",
          "publication_source": "String",
          "organism_id_interactor_a": "Int",
          "organism_id_interactor_b": "Int",
          "throughput": {
            "type": "String",
            "values": ["High Throughput", "High Throughput|Low Throughput", "Low Throughput"]
          },
          "score": "Float",
          "modification": "String",
          "qualifications": "String",
          "data_source": {
            "type": "String",
            "values": ["BIOGRID"]
          }
        }
      },
      "genetic_interaction": {
        "description": "Gene-gene genetic interactions from BioGRID",
        "source_node_type": "gene",
        "target_node_type": "gene",
        "properties": {
          "start": "String",
          "end": "String",
          "biogrid_interaction_id": "Int",
          "Entrez_ID_A": "Int",
          "Entrez_ID_B": "Int",
          "biogrid_id_interactor_a": "Int",
          "biogrid_id_interactor_b": "Int",
          "official_symbol_interactor_a": "String",
          "official_symbol_interactor_b": "String",
          "experimental_system": "String",
          "experimental_system_type": {
            "type": "String",
            "values": ["genetic"]
          },
          "author": "String",
          "publication_source": "String",
          "organism_id_interactor_a": "Int",
          "organism_id_interactor_b": "Int",
          "throughput": {
            "type": "String",
            "values": ["High Throughput", "High Throughput|Low Throughput", "Low Throughput"]
          },
          "score": "Float",
          "modification": "String",
          "qualifications": "String",
          "data_source": {
            "type": "String",
            "values": ["BIOGRID"]
          }
        }
      },
      "OCR_locate_in": {
        "description": "Relationship type: OCR_locate_in",
        "source_node_type": "OCR",
        "target_node_type": "gene",
        "properties": {
          "start": "String",
          "end": "String",
          "data_version": {
            "type": "String",
            "values": ["2025_05_28"]
          },
          "data_source": {
            "type": "String",
            "values": ["PanKbase"]
          }
        }
      },
      "OCR_activity": {
        "description": "Open chromatin region activity scores in different cell types and disease states",
        "source_node_type": "OCR",
        "target_node_type": "cell_type",
        "properties": {
          "start": "String",
          "end": "String",
          "OCR_GeneActivityScore_mean": "Float",
          "OCR_GeneActivityScore_median": "Float",
          "non_diabetic__OCR_GeneActivityScore_mean": "Float",
          "non_diabetic__OCR_GeneActivityScore_median": "Float",
          "AAB_pos__OCR_GeneActivityScore_mean": "Float",
          "AAB_pos__OCR_GeneActivityScore_median": "Float",
          "type_1_diabetes__OCR_GeneActivityScore_mean": "Float",
          "type_1_diabetes__OCR_GeneActivityScore_median": "Float",
          "type_2_diabetes__OCR_GeneActivityScore_mean": "Float",
          "type_2_diabetes__OCR_GeneActivityScore_median": "Float",
          "data_version": {
            "type": "String",
            "values": ["2025_05_28"]
          },
          "data_source": {
            "type": "String",
            "values": ["PanKbase"]
          }
        }
      },
      "function_annotation": {
        "description": "Gene Ontology annotations linking genes to their molecular functions, biological processes, and cellular components",
        "source_node_type": "gene",
        "target_node_type": "gene_ontology",
        "properties": {
          "start": "String",
          "end": "String",
          "data_version": {
            "type": "String",
            "values": ["GRCh38.p14"]
          },
          "data_source": {
            "type": "String",
            "values": ["Ensembl"]
          }
        }
      },
      "effector_gene_of": {
        "description": "Genes that are causal or almost certainly causal for Type 1 Diabetes based on genetic evidence",
        "source_node_type": "gene",
        "target_node_type": "disease",
        "properties": {
          "start": "String",
          "end": {
            "type": "String",
            "values": ["MONDO_0005147"]
          },
          "evidence": "String",
          "effector_gene_list_url": {
            "type": "String",
            "values": [
              "https://t1d.hugeamp.org/research.html?pageid=Atla_T1D_568",
              "https://t1d.hugeamp.org/research.html?pageid=T1D_UVa_168",
              "https://t1d.hugeamp.org/research.html?pageid=t1d_effector_genes"
            ]
          },
          "data_version": {
            "type": "String",
            "values": ["2025-10-24"]
          },
          "data_source_url": "String",
          "data_source": {
            "type": "String",
            "values": [
              "Type 1 diabetes effector gene predictions (Gaulton KJ, 2021)",
              "Type 1 diabetes predicted effector genes (Atla G et al. 2022)",
              "Type 1 diabetes predicted effector genes (Onengut-Gumuscu S and Rich SS, 2022)"
            ]
          }
        }
      },
      "part_of_GWAS_signal": {
        "description": "Relationship type: part_of_GWAS_signal",
        "source_node_type": "snp",
        "target_node_type": "disease",
        "properties": {
          "start": "String",
          "end": {
            "type": "String",
            "values": ["MONDO_0005147"]
          },
          "locus_name": "String",
          "credible_set_id": "String",
          "lead_status": {
            "type": "String",
            "values": ["lead", "nonlead"]
          },
          "pip": "Float",
          "p_value": "Float",
          "lbf": "Float",
          "effect_allele": {
            "type": "String",
            "values": ["A", "C", "G", "T"]
          },
          "non_effect_allele": {
            "type": "String",
            "values": ["A", "C", "G", "T"]
          },
          "pip_rank": "Int",
          "credible_set_size": "Int",
          "credible_set_purity": "Float",
          "method": {
            "type": "String",
            "values": ["GWAS"]
          },
          "data_source": {
            "type": "String",
            "values": ["GWAS_finemapping_V1"]
          },
          "data_source_url": {
            "type": "String",
            "values": ["https://pubmed.ncbi.nlm.nih.gov/34012112/"]
          },
          "data_version": {
            "type": "String",
            "values": ["10/18/2025"]
          }
        }
      },
      "expression_level_in": {
        "description": "Gene expression summary statistics per cell type (NonDiabetic, Type1Diabetic, All conditions)",
        "source_node_type": "gene",
        "target_node_type": "cell_type",
        "properties": {
          "start": "String",
          "end": {
            "type": "String",
            "values": ["CL_0000169", "CL_0000171", "CL_0000173", "CL_0002064", "CL_0002079"]
          },
          "NonDiabetic__expression_mean": "Float",
          "NonDiabetic__expression_min": "Float",
          "NonDiabetic__expression_25_quantile": "Float",
          "NonDiabetic__expression_median": "Float",
          "NonDiabetic__expression_75_quantile": "Float",
          "NonDiabetic__expression_max": "Float",
          "Type1Diabetic__expression_mean": "Float",
          "Type1Diabetic__expression_min": "Float",
          "Type1Diabetic__expression_25_quantile": "Float",
          "Type1Diabetic__expression_median": "Float",
          "Type1Diabetic__expression_75_quantile": "Float",
          "Type1Diabetic__expression_max": "Float",
          "All__expression_mean": "Float",
          "All__expression_min": "Float",
          "All__expression_25_quantile": "Float",
          "All__expression_median": "Float",
          "All__expression_75_quantile": "Float",
          "All__expression_max": "Float",
          "data_version": {
            "type": "String",
            "values": ["V3.3"]
          },
          "data_source": {
            "type": "String",
            "values": ["PanKbase"]
          }
        }
      },
      "DEG_in": {
        "description": "Differential gene expression in a cell type (T1D vs non-diabetic)",
        "source_node_type": "gene",
        "target_node_type": "cell_type",
        "properties": {
          "start": "String",
          "end": {
            "type": "String",
            "values": ["CL_0000169", "CL_0000171", "CL_0000173", "CL_0002064", "CL_0002079"]
          },
          "UpOrDownRegulation": {
            "type": "String",
            "values": ["Upregulated in T1D", "Downregulated in T1D"]
          },
          "Log2FoldChange": "Float",
          "SE_of_Log2FoldChange": "Float",
          "P_value": "Float",
          "Adjusted_P_value": "Float",
          "data_version": {
            "type": "String",
            "values": ["2025-05-28"]
          },
          "data_source": {
            "type": "String",
            "values": ["PanKbase"]
          }
        }
      },
      "signal_COLOC_with": {
        "description": "Colocalization analysis between QTL signals and GWAS signals for Type 1 Diabetes",
        "source_node_type": "gene",
        "target_node_type": "disease",
        "properties": {
          "start": "String",
          "end": {
            "type": "String",
            "values": ["MONDO_0005147"]
          },
          "QTL_locus_name": "String",
          "GWAS_locus_name": "String",
          "QTL_signal_id": "String",
          "GWAS_signal_id": "String",
          "nsnp": "Int",
          "GWAS_lead_vars": "String",
          "QTL_lead_vars": "String",
          "PP.H0.abf": "Float",
          "PP.H1.abf": "Float",
          "PP.H2.abf": "Float",
          "PP.H3.abf": "Float",
          "PP.H4.abf": "Float",
          "coloc_dataset": {
            "type": "String",
            "values": [
              "t1d_eQTL-gtex_coloc",
              "t1d_eQTL-inspire_coloc",
              "t1d_exonQTL-inspire_coloc",
              "t1d_sQTL-gtex_coloc"
            ]
          },
          "data_source": {
            "type": "String",
            "values": ["HIRN_T1D_QTL_GWAS"]
          },
          "data_version": {
            "type": "String",
            "values": ["v1.0"]
          }
        }
      },
      "part_of_QTL_signal": {
        "description": "Quantitative trait loci associations between genetic variants and gene expression",
        "source_node_type": "snp",
        "target_node_type": "gene",
        "properties": {
          "start": "String",
          "end": "String",
          "tissue_name": {
            "type": "String",
            "values": ["Islet", "Pancreas"]
          },
          "tissue_id": "String",
          "credible_set": "String",
          "gene_name": "String",
          "credibleset": "String",
          "pip": "Float",
          "nominal_p": "Float",
          "lbf": "Float",
          "effect_allele": {
            "type": "String",
            "values": ["A", "C", "G", "T"]
          },
          "other_allele": {
            "type": "String",
            "values": ["A", "C", "G", "T"]
          },
          "slope": "Float",
          "n_snp": "Int",
          "purity": "Float",
          "data_version": {
            "type": "String",
            "values": ["02/03/25"]
          },
          "data_source": {
            "type": "String",
            "values": ["GTEx; SusieR", "INSPIRE; SusieR", "exon; INSPIRE", "splicing; GTEx"]
          }
        }
      }
    }
  }
}